# Portainer stack name: cliente-a
# Compose path: stacks/docker-compose.yml   <-- NOT docker-compose.portainer.yml
# SIP test: sipsak ... -r 5060
# sngrep:   SIP_NETWORK=cliente-a_sip_net
# Expect 8 containers: postgres, opensips, freeswitch-1, freeswitch-2, haproxy, 3 exporters

POSTGRES_PASSWORD=changeme_cliente_a
HAPROXY_BACKEND_SERVERS=38.68.135.36:8080,167.88.62.66:8080

# Host ports (unique across all stacks on this Docker host)
OPENSIPS_SIP_PORT=5060
OPENSIPS_ALT_SIP_PORT=5070
OPENSIPS_EXPORTER_PORT=9434
FREESWITCH_EXPORTER_PORT_1=9282
FREESWITCH_EXPORTER_PORT_2=9283

# RTP ranges — FS-1 and FS-2 must not overlap with other stacks
FS1_RTP_START_PORT=16384
FS1_RTP_END_PORT=18021
FS2_RTP_START_PORT=18022
FS2_RTP_END_PORT=19659

# Dispatcher set 101 — both FreeSWITCH nodes (internal hostnames)
DISPATCHER_DESTINATIONS=sip:freeswitch-1:5080,sip:freeswitch-2:5080

SRC_IP_WHITELIST=0.0.0.0/0
CARRIER_ROUTES=prefix:52,split:2,host:pbx-lab.piwiit.com:5080

# Public IP of this Docker host (required for real RTP audio)
FS_EXTERNAL_RTP_IP=203.0.113.10
FS_EXTERNAL_SIP_IP=auto

MEDIA_OUT=false
VXT_ANSWER_DETECT=false
TIMEOUTMS_ANSWER_VXT=2300
VXT_WS_EXCLUDE_PREANSWER=
VXT_WS_EXCLUDE_ANSWER=
